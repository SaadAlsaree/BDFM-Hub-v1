using BDFM.Web;
using Serilog;
using System.Diagnostics;
using System.Linq;
using System.Threading.Tasks;

Log.Logger = new LoggerConfiguration()
    .WriteTo.Console()
    .CreateBootstrapLogger();

Log.Information("BDFM API Starting up!");

var builder = WebApplication.CreateBuilder(args);

builder.Host.UseSerilog((context, loggerConfiguration) => loggerConfiguration
     .WriteTo.Console()
     .ReadFrom.Configuration(context.Configuration));

builder.Services.AddLogging();

var app = builder
    .ConfigureServices()
    .ConfigurePipeline();

app.UseSerilogRequestLogging();

// Open default browser to app URL after a short delay so the server is listening
try
{
    // Determine candidate URL from configuration or fallback
    var configured = builder.Configuration["applicationUrl"] ?? builder.Configuration["urls"];
    var url = configured?.Split(';', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()
              ?? "https://localhost:5001";

    Task.Run(async () =>
    {
        // small delay to let the server start listening
        await Task.Delay(1200);
        try
        {
            var psi = new ProcessStartInfo { FileName = url, UseShellExecute = true };
            Process.Start(psi);
        }
        catch
        {
            // swallow any exception when attempting to open the browser
        }
    });
}
catch
{
    // ignore any issues determining URL or launching browser
}

//await app.ResetDatabaseAsync();

