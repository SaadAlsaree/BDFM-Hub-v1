# Server Configuration
PORT=3001
NODE_ENV=development

# PostgreSQL Configuration (BDFM Main Database)
POSTGRES_HOST=cm-db.inss.local
POSTGRES_PORT=5432
POSTGRES_DB=cmdb
POSTGRES_USER=cmuser
POSTGRES_PASSWORD=@DYKMk7xjB25

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen2.5:3b
OLLAMA_CHAT_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT=120000

# RAG Configuration
EMBEDDING_DIMENSION=3584
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_RESULTS=10
SIMILARITY_THRESHOLD=0.7

# Collection Names
CORRESPONDENCE_COLLECTION=bdfm_correspondences
WORKFLOW_COLLECTION=bdfm_workflows
USER_GUIDE_COLLECTION=bdfm_user_guide

# Logging
LOG_LEVEL=info
LOG_FILE=logs/bdfm-rag.log

# Speech-to-Text Configuration
WHISPER_MODEL=whisper:latest
MAX_AUDIO_FILE_SIZE=26214400
MAX_AUDIO_DURATION=600
UPLOAD_DIR=uploads/audio

# Statistics Configuration
STATS_CACHE_ENABLED=true
STATS_CACHE_TTL=300
STATS_DEFAULT_LIMIT=100
